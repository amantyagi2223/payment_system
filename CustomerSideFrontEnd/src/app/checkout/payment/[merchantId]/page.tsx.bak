"use client";

import {
  createOrder,
  getOrder,
  listBlockchains,
  listProducts,
  verifyOrderPayment,
} from "@/lib/api-client";
import { useAuthStore } from "@/store/authStore";
import { useRateStore } from "@/store/rateStore";
import type {
  BlockchainListItem,
  CreateOrderResponse,
  OrderStatus,
  ProductListItem,
} from "@/lib/api-client";

import Protected from "@/components/Protected";
import Link from "next/link";
import { useCartStore } from "@/store/cartStore";
import type { CartItem } from "@/store/cartStore";
import { useParams, useRouter, useSearchParams } from "next/navigation";
import { Suspense, useEffect, useMemo, useState, useCallback } from "react";
import QRCode from "react-qr-code";

const NATIVE_TOKEN_SYMBOL_BY_CHAIN: Record<number, string> = {
  56: "BNB",
  97: "BNB",
  137: "MATIC",
  80002: "MATIC",
  728126428: "TRX",
  3448148188: "TRX",
};

const SUPPORTED_PAYMENT_SYMBOLS = new Set([
  "ETH", "WETH", "BNB", "WBNB", "MATIC", "POL", "WMATIC", "USDT", "USDC", "USDT.E", "USDC.E", "TRX",
]);

function getNativeTokenSymbol(chainId: number): string {
  return NATIVE_TOKEN_SYMBOL_BY_CHAIN[chainId] ?? "ETH";
}

function normalizePaymentSymbol(value?: string | null): string | null {
  const normalized = value?.trim().toUpperCase();
  if (!normalized || !SUPPORTED_PAYMENT_SYMBOLS.has(normalized)) return null;
  if (normalized === "USDT.E") return "USDT";
  if (normalized === "USDC.E") return "USDC";
  return normalized;
}

type ResolvedPaymentToken = {
  symbol: string;
  contractAddress?: string | null;
  decimals?: number | null;
};

function resolvePaymentToken(
  order: CreateOrderResponse, 
  product: ProductListItem | null
): ResolvedPaymentToken {
  // Extract from order response or fallback
  const symbol = (order as any).currency || order.network?.name || getNativeTokenSymbol(order.network?.chainId || 1) || 'ETH';
  return {
    symbol,
    contractAddress: null,
    decimals: symbol === 'ETH' ? 18 : 6,
  };
}

export default function PaymentPage() {
  return (
    <Suspense fallback={<div className="flex items-center justify-center min-h-[80vh] text-slate-400">Loading payment...</div>}>
      <PaymentContent />
    </Suspense>
  );
}

function PaymentContent() {
  const params = useParams();
  const searchParams = useSearchParams();
  const router = useRouter();

  const merchantId = params.merchantId as string;
  const addressIdParam = searchParams.get('addressId');
  const productIdParam = searchParams.get('productId');

  const { token, shippingAddresses, loadShippingAddresses } = useAuthStore();
  const cartStore = useCartStore();
  const rateStore = useRateStore();
  
  // State
  const [cartItems, setCartItems] = useState<CartItem[]>([]);
  const [product, setProduct] = useState<ProductListItem | null>(null);
  const [isCartMode, setIsCartMode] = useState(true);
  const [selectedAddressId, setSelectedAddressId] = useState<string | null>(addressIdParam || null);
  const [blockchains, setBlockchains] = useState<BlockchainListItem[]>([]);
  const [selectedBlockchainId, setSelectedBlockchainId] = useState<string>("");
  const [selectedCurrency, setSelectedCurrency] = useState<'ETH' | 'USDC' | 'USDT'>('ETH');
  const [order, setOrder] = useState<CreateOrderResponse | null>(null);
  const [orderStatus, setOrderStatus] = useState<OrderStatus | null>(null);
  const [txHash, setTxHash] = useState("");
  const [verifying, setVerifying] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);
  const [addressesLoading, setAddressesLoading] = useState(false);

  const deliveryFee = cartStore.getDeliveryFee(merchantId);
  const totalUSD = cartStore.getTotalUSD(merchantId);
  const previewCryptoAmount = rateStore.getCryptoAmount(totalUSD, selectedCurrency);

  // Auto-resolve payment token
  const paymentToken = useMemo(() => {
    if (!order) return null;
    return resolvePaymentToken(order, product);
  }, [order, product]);

  // Load data on mount
  useEffect(() => {
    const init = async () => {
      setLoading(true);
      setError(null);

      // Load addresses
      if (token && shippingAddresses.length === 0) {
        setAddressesLoading(true);
        try {
          await loadShippingAddresses();
        } catch (err) {
          console.error('Failed to load addresses:', err);
        } finally {
          setAddressesLoading(false);
        }
      }

      // Load cart/product
      const items = cartStore.getCartForMerchant(merchantId);
      setCartItems(items);
      if (items.length === 0 && productIdParam) {
        setIsCartMode(false);
        try {
          const products = await listProducts();
          const selected = products.find(p => p.id === productIdParam);
          setProduct(selected || null);
        } catch (err) {
          setError('Product not found');
        }
      } else if (items.length === 0) {
        setError('No cart items or product found');
      }

      // Load blockchains
      try {
        const chains = await listBlockchains();
        setBlockchains(chains);
        if (chains.length > 0 && !selectedBlockchainId) {
          setSelectedBlockchainId(chains[0].id);
        }
      } catch (err) {
        setError('Failed to load blockchains');
      }

      // Load rates
      rateStore.fetchAllRates();

      setLoading(false);
    };

    if (token) init();
  }, [token, merchantId, productIdParam, cartStore]);

  const handleCreateOrder = useCallback(async () => {
    if (!token || !selectedBlockchainId || (!cartItems.length && !product) || cartStore.getTotalUSD(merchantId) <= 0) {
      setError('Missing: login, blockchain, items, or cart total');
      return;
    }

    try {
      setError(null);
      setVerifying(true);
      const ethPrice = selectedCurrency === 'ETH' ? rateStore.getEthPrice() : undefined;

      const items: {productId: string, quantity: number}[] = isCartMode 
        ? cartItems.map(item => ({productId: item.productId, quantity: item.qty}))
        : [{productId: product!.id, quantity: 1}];

      const createdOrder = await createOrder(
        token, 
        items, 
        selectedBlockchainId, 
        selectedAddressId || undefined,
        selectedCurrency,
        ethPrice
      );

      setOrder(createdOrder);
      const latestOrder = await getOrder(token, createdOrder.orderId);
      setOrderStatus(latestOrder.status);
    } catch (err: any) {
      const msg = err.message || 'Order creation failed - check backend logs';
      setError(`createOrder failed: ${msg} (Backend: http://127.0.0.1:3000/orders)`);
      console.error('createOrder error:', err);
    } finally {
      setVerifying(false);
    }
  }, [token, selectedBlockchainId, selectedCurrency, selectedAddressId, cartItems, product, isCartMode, rateStore, cartStore, merchantId]);

  const handleVerifyPayment = useCallback(async () => {
    if (!token || !order || !txHash.trim()) return;

    try {
      setVerifying(true);
      await verifyOrderPayment(token, order.orderId, txHash.trim(), true);
      const latestOrder = await getOrder(token, order.orderId);
      setOrderStatus(latestOrder.status);
    } catch (err: any) {
      setError(`Verify failed: ${err.message}`);
    } finally {
      setVerifying(false);
    }
  }, [token, order, txHash]);

  if (!token) {
    return (
      <Protected>
        <div className="min-h-[80vh] flex flex-col items-center justify-center text-center px-6">
          <h2 className="text-2xl font-bold mb-4">Login Required</h2>
          <Link href="/login" className="px-8 py-4 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold rounded-2xl shadow-lg transition-all">
            Login to Pay
          </Link>
        </div>
      </Protected>
    );
  }

  return (
    <Protected>
      <div className="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-white p-4 md:p-8">
        <div className="max-w-4xl mx-auto">
          {/* Header */}
          <div className="mb-12 text-center">
            <button onClick={() => router.back()} className="absolute left-4 top-8 p-3 bg-slate-800/50 hover:bg-slate-700 rounded-2xl transition-all md:left-8">
              <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <h1 className="text-4xl md:text-5xl font-black bg-gradient-to-r from-cyan-400 via-purple-400 to-emerald-400 bg-clip-text mb-4">
              Secure Payment
            </h1>
            <p className="text-2xl font-bold text-slate-200">${totalUSD.toFixed(2)} USD</p>
            <p className="text-slate-400 mt-2">Merchant: {merchantId.slice(0,8)}... | Address ID: {selectedAddressId?.slice(0,8)}...</p>
          </div>

          {loading && (
            <div className="flex items-center justify-center py-24">
              <div className="text-center">
                <div className="w-16 h-16 border-4 border-slate-700 border-t-cyan-400 rounded-full animate-spin mx-auto mb-4"></div>
                <p>Loading blockchains, rates, addresses...</p>
              </div>
            </div>
          )}

          {!loading && (
            <>
              {/* Pre-Order Selections */}
              {!order ? (
                <div className="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
                  {/* Blockchain */}
                  <div className="bg-slate-900/70 backdrop-blur-xl border border-slate-800/50 rounded-3xl p-8 shadow-2xl">
                    <h3 className="text-2xl font-bold mb-6 flex items-center gap-3">
                      <svg className="w-8 h-8 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Blockchain Network
                    </h3>
                    <div className="grid grid-cols-2 gap-4">
                      {blockchains.map(chain => (
                        <button
                          key={chain.id}
                          onClick={() => setSelectedBlockchainId(chain.id)}
                          className={`p-6 rounded-2xl border-2 transition-all hover:scale-105 group ${
                            selectedBlockchainId === chain.id
                              ? 'bg-gradient-to-r from-cyan-500/20 border-cyan-400 shadow-cyan-500/25 ring-2 ring-cyan-500/50'
                              : 'bg-slate-800/50 border-slate-700 hover:border-slate-600'
                          }`}
                        >
                          <p className={`font-bold mb-1 ${selectedBlockchainId === chain.id ? 'text-cyan-300' : 'text-white'}`}>
                            {chain.name}
                          </p>
                          <p className="text-sm text-slate-400">ID: {chain.chainId}</p>
                        </button>
                      ))}
                    </div>
                  </div>

                  {/* Currency & Preview */}
                  <div className="bg-slate-900/70 backdrop-blur-xl border border-slate-800/50 rounded-3xl p-8 shadow-2xl space-y-6">
                    <h3 className="text-2xl font-bold flex items-center gap-3 text-emerald-400">
                      <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Pay With
                    </h3>
                    <select 
                      value={selectedCurrency} 
                      onChange={(e) => setSelectedCurrency(e.target.value as 'ETH'|'USDC'|'USDT')}
                      className="w-full p-6 bg-slate-800/50 border-2 border-emerald-500/30 rounded-3xl text-2xl font-bold text-white focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/30 transition-all"
                    >
                      <option value="ETH">ETH / Native Token</option>
                      <option value="USDC">USDC (Stable $1)</option>
                      <option value="USDT">USDT (Stable $1)</option>
                    </select>
                    <div className="p-8 bg-gradient-to-br from-emerald-500/10 rounded-3xl border border-emerald-500/30 shadow-xl">
                      <div className="text-5xl font-black text-emerald-400 mb-4">{previewCryptoAmount.toFixed(4)} {selectedCurrency}</div>
                      <div className="text-xl text-slate-300 flex items-center justify-center gap-2">
                        = <span className="text-emerald-400 font-bold">${totalUSD.toFixed(2)}</span> USD
                      </div>
                      <p className="text-sm text-slate-400 mt-2">Live rates | Updated {new Date(rateStore.lastUpdated || 0).toLocaleTimeString()}</p>
                    </div>
                  </div>
                </div>
              ) : (
                /* Post-order wallet display - simplified for brevity */
                <div className="bg-gradient-to-br from-slate-900/90 rounded-3xl p-12 border border-slate-800/50 shadow-2xl mb-8 text-center">
                  <h2 className="text-4xl font-black mb-8 bg-gradient-to-r from-emerald-400 to-cyan-400 -bg-clip-text">
                    Send {order.amount} to:
                  </h2>
                  <div className="bg-slate-800/60 p-6 rounded-3xl mb-8">
                    <code className="font-mono text-2xl text-cyan-300 break-all block mb-4 select-all">{order.walletAddress}</code>
                    <QRCode value={`ethereum:${order.walletAddress}?value=${order.amount}`} size={256} />
                  </div>
                  {/* Verify TX input/button here */}
                </div>
              )}

              {/* Create Order Button (pre-order) */}
              {!order && !loading && (
                <div className="text-center">
                  <button
                    onClick={handleCreateOrder}
                    disabled={!selectedBlockchainId || rateStore.loading || verifying}
                    className="px-16 py-8 bg-gradient-to-r from-purple-600 via-emerald-600 to-cyan-600 hover:from-purple-500 hover:to-cyan-500 text-2xl font-black rounded-3xl shadow-2xl shadow-purple-600/30 hover:shadow-purple-600/50 transition-all text-white disabled:opacity-50 w-full md:w-auto"
                  >
                    {verifying ? 'Creating...' : '🚀 Generate Secure Wallet Address'}
                  </button>
                </div>
              )}

              {/* Errors */}
              {error && (
                <div className="p-8 rounded-3xl border-2 border-red-500/30 bg-red-500/10 text-center">
                  <h3 className="text-xl font-bold text-red-400 mb-4">Error</h3>
                  <p className="text-red-300 mb-4">{error}</p>
                  <button onClick={() => setError(null)} className="px-8 py-3 bg-slate-700 hover:bg-slate-600 rounded-2xl text-white transition-all">
                    Retry
                  </button>
                </div>
              )}

              {/* Address Debug (temp) */}
              {selectedAddressId && (
                <div className="p-4 bg-slate-900/50 rounded-2xl text-xs text-slate-400 text-center">
                  Debug: merchantId={merchantId} addrId={selectedAddressId} blockchainId={selectedBlockchainId} cartItems={cartItems.length} token={!!token}
                </div>
              )}
            </>
          )}

          {/* Back link */}
          <div className="mt-12 text-center">
            <Link href={`/checkout/review/${merchantId}`} className="inline-flex items-center gap-2 text-slate-400 hover:text-slate-200 transition-colors">
              ← Back to Review
            </Link>
          </div>
        </div>
      </div>
    </Protected>
  );
}
